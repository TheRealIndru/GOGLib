def parse_allowed_langs(lang_str):
    out = set()
    for part in re.split(r"[+,]", (lang_str or "").lower()):
        part = part.strip()
        if not part:
            continue
        if part == "all":
            return None
        for primary, aliases in LANG_FILENAME_TOKENS.items():
            if part == primary or part in aliases:
                out.add(primary)
                break
    return out


def build_extra_lang_blacklist_patterns(allowed_langs):
    if allowed_langs is None:
        return []
    bad = set()
    for primary, aliases in LANG_FILENAME_TOKENS.items():
        if primary in allowed_langs:
            continue
        for tok in aliases:
            bad.add(tok)
    if not bad:
        return []
    tokens = sorted(bad, key=len, reverse=True)
    tok_re = "|".join(re.escape(t) for t in tokens)
    exts = "|".join(AUDIT_EXTS)
    return [f".*_({tok_re})\\.({exts})$"]


def build_blacklist(manifest, slugs, cfg, games_to_sync):
    """Generate lgog --blacklist file.

    Includes:
      - per-file entries for EVERYTHING in manifest, regardless of current sync
        scope (cheap; ensures no regression if scope shifts unexpectedly)
      - OST format-priority blacklist (per game in current sync scope)
      - language-token patterns (only if extras_lang_filter is true)
      - any user-defined extra patterns from cfg
    """
    lines = ["# Auto-generated by goglib — do not edit manually"]

    n_done = 0
    for key, info in manifest.get("files", {}).items():
        slug = info.get("slug") or key.split("/", 1)[0]
        fname = info.get("original_filename") or key.split("/", 1)[1]
        # NO leading ^ anchor — lgog passes paths with a leading '/' in some
        # versions, which breaks anchored patterns. regex_search semantics
        # mean unanchored is fine and works regardless of leading slash.
        lines.append(f"Rp {re.escape(slug)}/(.*/)?{re.escape(fname)}$")
        n_done += 1

    n_ost = 0
    ost_priority = cfg.get("ost_format_priority", [])
    if ost_priority:
        for game in games_to_sync:
            for pat in build_ost_blacklist_for_game(game, ost_priority):
                lines.append(f"Rp {pat}")
                n_ost += 1

    n_lang = 0
    if cfg.get("extras_lang_filter", False):
        allowed = parse_allowed_langs(cfg.get("language", ""))
        for pat in build_extra_lang_blacklist_patterns(allowed):
            lines.append(f"Rp {pat}")
            n_lang += 1

    n_user = 0
    for pat in cfg.get("extra_blacklist_patterns", []) or []:
        lines.append(f"Rp {pat}")
        n_user += 1

    BLACKLIST_TMP.write_text("\n".join(lines) + "\n")
    return n_done, n_ost, n_lang, n_user


def cmd_plan(args, cfg):
    library = load_library()
    games = filter_games(library, args.letter, args.game)
    manifest = load_manifest()
    files_done = set(manifest.get("files", {}).keys())

