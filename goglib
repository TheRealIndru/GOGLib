# ---------- helpers ----------
def log(msg):
    line = f"[{datetime.now().isoformat(timespec='seconds')}] {msg}"
    print(line)
    LOG_PATH.parent.mkdir(parents=True, exist_ok=True)
    with open(LOG_PATH, "a") as f:
        f.write(line + "\n")


def fmt_size(n):
    n = float(n)
    for unit in ("B", "KiB", "MiB", "GiB", "TiB"):
        if n < 1024:
            return f"{n:.2f} {unit}"
        n /= 1024
    return f"{n:.2f} PiB"


def parse_size(v):
    if v is None or v == "":
        return 0
    if isinstance(v, (int, float)):
        return int(v)
    s = str(v).strip()
    try:
        return int(float(s))
    except ValueError:
        return 0


def safe_dir(s, replace_spaces=True):
    s = re.sub(r'[<>:"/\\|?*\x00]', "_", s).strip().rstrip(".")
    if replace_spaces:
        s = re.sub(r"\s+", "_", s)
    return s


def mkey(slug, fname):
    return f"{slug}/{fname}"


