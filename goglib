        title = entries[0].get("title") if entries else None
        c = title_first_char(title or slug)
        by_letter[c] = by_letter.get(c, 0) + 1
    print("\nGames by first letter (title-based, articles stripped):")
    for c in sorted(by_letter):
        print(f"  {c}: {by_letter[c]}")


def cmd_config(args, cfg):
    if args.write_default:
        write_default_config()
        return
    print(f"Config file:     {CONFIG_PATH} (exists: {CONFIG_PATH.exists()})")
    print(f"Franchises file: {FRANCHISES_PATH} (exists: {FRANCHISES_PATH.exists()})")
    print("\nEffective config:")
    for k, v in cfg.items():
        print(f"  {k}: {v}")


def main():
    p = argparse.ArgumentParser(prog="goglib", description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("refresh", help="Refresh lgog cache + library JSON")
    sp.set_defaults(func=cmd_refresh)

    sp = sub.add_parser("plan", help="Show what would be downloaded")
    sp.add_argument("--letter", default=None)
    sp.add_argument("--game", default=None)
    sp.set_defaults(func=cmd_plan)

    sp = sub.add_parser("sync", help="Download new files and organize")
    sp.add_argument("--letter", default=None)
    sp.add_argument("--game", default=None)
    sp.add_argument("--verbose", action="store_true",
                    help="Pass verbosity flag to the backend (shows skip messages)")
    sp.set_defaults(func=cmd_sync)

    sp = sub.add_parser("process",
                        help="Post-process existing staging without re-downloading")
    sp.add_argument("--letter", default=None)
    sp.add_argument("--game", default=None)
    sp.set_defaults(func=cmd_process)

    sp = sub.add_parser("audit",
                        help="Interactively review extras matching language tokens")
    sp.add_argument("--review-all", action="store_true")
    sp.set_defaults(func=cmd_audit)

    sp = sub.add_parser("reorganize",
                        help="Move files in library to match current config")
    sp.add_argument("--dry-run", action="store_true")
    sp.set_defaults(func=cmd_reorganize)

    sp = sub.add_parser("forget",
                        help="Remove matching entries from manifest")
    sp.add_argument("--letter", default=None)
    sp.add_argument("--game", default=None)
    sp.add_argument("--yes", action="store_true", help="Skip confirmation")
    sp.set_defaults(func=cmd_forget)

    sp = sub.add_parser("status", help="Manifest summary")
    sp.set_defaults(func=cmd_status)

    sp = sub.add_parser("config", help="Show or initialize config")
    sp.add_argument("--write-default", action="store_true")
    sp.set_defaults(func=cmd_config)

    args = p.parse_args()
    cfg = load_config()
    args.func(args, cfg)


if __name__ == "__main__":
    main()
