          + (f" game~/{args.game}/" if args.game else "")
          + f" — {len(games)} games ===\n")

    rows = []
    total_size = 0
    for g in games:
        slug = g["gamename"]
        title = g.get("title", slug)
        gtotal, gcount = expected_size_total(g)
        done_for_slug = sum(1 for k in files_done if k.startswith(f"{slug}/"))
        total_size += gtotal
        rows.append((gtotal, gcount, done_for_slug, slug, title))

    rows.sort(reverse=True)
    for gtotal, gcount, done, slug, title in rows:
        if done == 0:
            tag = "NEW    "
        elif done >= gcount:
            tag = "DONE   "
        else:
            tag = "PARTIAL"
        print(f"  [{tag}] {fmt_size(gtotal):>11s}  ({done}/{gcount} files done)  {title}")

    # Show OST format-filter savings preview
    ost_priority = cfg.get("ost_format_priority", [])
    if ost_priority:
        ost_savings = 0
        for g in games:
            patterns = build_ost_blacklist_for_game(g, ost_priority)
            if not patterns:
                continue
            for f in (g.get("extras") or []):
                fname = (f.get("path") or "").rsplit("/", 1)[-1]
                if not fname:
                    continue
