# ---------- per-OS paths ----------
def _config_dir():
    """Location of config files. Respects XDG on Linux/macOS, APPDATA on Windows."""
    if IS_WINDOWS:
        appdata = os.environ.get("APPDATA")
        if appdata:
            return Path(appdata) / "goglib"
        return HOME / "AppData" / "Roaming" / "goglib"
    xdg = os.environ.get("XDG_CONFIG_HOME")
    return (Path(xdg) if xdg else HOME / ".config") / "goglib"


def _state_dir():
    """Location of manifest and library snapshot. XDG_DATA on Linux, APPDATA on Windows."""
    if IS_WINDOWS:
        appdata = os.environ.get("APPDATA")
        if appdata:
            return Path(appdata) / "goglib"
        return HOME / "AppData" / "Roaming" / "goglib"
    xdg = os.environ.get("XDG_DATA_HOME")
    return (Path(xdg) if xdg else HOME / ".local" / "share") / "goglib"


def _temp_dir():
    """Location for transient files (blacklist, report). Auto-cleaned by OS."""
    return Path(tempfile.gettempdir())


