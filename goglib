def process_staging(cfg, slugs, library_index, franchises, manifest):
    """Walk staging for each slug, move files to library, update manifest."""
    library_root = Path(cfg["library_dir"])
    versions_root = Path(cfg["versions_dir"])
    library_root.mkdir(parents=True, exist_ok=True)

    new_count = ver_count = skip_count = 0

    for slug in sorted(slugs):
        game = library_index.get(slug)
        if not game:
            log(f"  [{slug}] not in library JSON, skipping")
            continue

        staging_slug = Path(cfg["staging_dir"]) / slug
        if not staging_slug.exists():
            continue

        files = []
        for p in staging_slug.rglob("*"):
            if not p.is_file():
                continue
            if p.suffix in (".tmp", ".part") or p.name.endswith(".tmp"):
                continue
            files.append(p)

        if not files:
            log(f"  [{slug}] staging exists but no complete files found")
            continue

        log(f"  [{slug}] processing {len(files)} files")
        target_dir = target_dir_for(game, library_index, library_root, franchises, cfg)
        dlc_slug_for_rename = slug if is_dlc(game) and cfg.get("flatten_dlc_folder", True) else None

        for src_path in files:
            rel = src_path.relative_to(staging_slug)
            kind, rel_subdir = derive_kind(str(rel.parent))

            new_name = rename_for_target(src_path.name, cfg, dlc_slug=dlc_slug_for_rename)
            dest_dir = target_dir / rel_subdir if rel_subdir else target_dir
            dest_dir.mkdir(parents=True, exist_ok=True)
            dest_path = dest_dir / new_name

            if dest_path.exists():
                ts = datetime.now().strftime("%Y%m%d-%H%M%S")
                vpath = versions_root / safe_dir(slug,
                            cfg.get("dir_replace_spaces", True)) / ts / new_name
                vpath.parent.mkdir(parents=True, exist_ok=True)
                shutil.move(str(dest_path), str(vpath))
                log(f"    [{slug}] versioned existing {new_name} -> {vpath}")
                ver_count += 1

            try:
                shutil.move(str(src_path), str(dest_path))
            except Exception as e:
                log(f"    [{slug}] FAILED to move {src_path.name}: {e}")
                skip_count += 1
                continue

            log(f"    [{slug}] {src_path.name} -> {dest_path}")
            manifest["files"][mkey(slug, src_path.name)] = {
                "slug": slug,
                "title": game.get("title") or slug,
                "original_filename": src_path.name,
                "renamed": new_name,
                "destination": str(dest_path),
                "size": dest_path.stat().st_size,
                "kind": kind,
                "is_dlc": is_dlc(game),
                "downloaded_at": datetime.now().isoformat(timespec="seconds"),
                "status": "downloaded",
            }
            new_count += 1

        if staging_slug.exists():
            for d in sorted([p for p in staging_slug.rglob("*") if p.is_dir()],
                            key=lambda p: -len(str(p))):
                try:
                    d.rmdir()
                except OSError:
                    pass
            try:
                staging_slug.rmdir()
            except OSError:
                pass

    return new_count, ver_count, skip_count


def cmd_audit(args, cfg):
    library_root = Path(cfg["library_dir"])
    if not library_root.exists():
        print(f"Library dir doesn't exist: {library_root}")
        return

    allowed = parse_allowed_langs(cfg.get("language", ""))
    if allowed is None:
        print("Language config is 'all' — nothing to audit.")
        return

    bad_tokens = set()
    for primary, aliases in LANG_FILENAME_TOKENS.items():
        if primary in allowed:
            continue
        bad_tokens.update(aliases)

    if not bad_tokens:
        print("No bad tokens (allowed languages cover everything).")
        return

    tokens = sorted(bad_tokens, key=len, reverse=True)
    tok_re = "|".join(re.escape(t) for t in tokens)
    exts = "|".join(AUDIT_EXTS)
    pattern = re.compile(f".*_({tok_re})\\.({exts})$", re.IGNORECASE)

    manifest = load_manifest()
    files_by_dest = {}
    for k, f in manifest.get("files", {}).items():
        dest = f.get("destination")
        if dest:
            files_by_dest[dest] = (k, f)

    matches = [p for p in library_root.rglob("*")
               if p.is_file() and pattern.match(p.name.lower())]

    if not matches:
        print("No files match suspicious language patterns.")
        return

    if not args.review_all:
        to_review = [p for p in matches
                     if not (files_by_dest.get(str(p), (None, {}))[1].get("audited"))]
    else:
        to_review = matches

    print(f"Found {len(matches)} files matching language token patterns.")
    if len(to_review) < len(matches):
        print(f"({len(matches) - len(to_review)} previously audited; "
              f"use --review-all to see them again.)")
    print(f"Reviewing {len(to_review)}.")
    print(f"Allowed languages: {sorted(allowed)}")
    print(f"\nKeys: [k]eep / [d]elete / [s]kip rest of this game / [q]uit and save\n")

    deleted = kept = 0
    skip_games = set()

    try:
        i = 0
        for p in to_review:
            i += 1
            try:
                rel = p.relative_to(library_root)
            except ValueError:
                continue
            game_folder = "/".join(rel.parts[:-1]) if len(rel.parts) > 1 else "?"
            top_folder = rel.parts[0] if rel.parts else "?"

            if top_folder in skip_games:
                continue

            size = p.stat().st_size
            m = pattern.match(p.name.lower())
            token = m.group(1) if m else "?"

            print(f"\n[{i}/{len(to_review)}] Token matched: '{token}'")
            print(f"  Game folder: {game_folder}")
            print(f"  File:        {p.name}")
            print(f"  Size:        {fmt_size(size)}")

            try:
                ans = input("  [k/d/s/q]: ").lower().strip()
            except (EOFError, KeyboardInterrupt):
                print("\nInterrupted.")
                break

            if ans == "q":
                print("Quit.")
                break
            elif ans == "s":
                skip_games.add(top_folder)
                print(f"  Skipping rest of '{top_folder}'.")
            elif ans == "d":
                try:
                    p.unlink()
                    deleted += 1
                    entry = files_by_dest.get(str(p))
                    if entry:
                        _, info = entry
                        info["status"] = "deleted"
                        info["audited"] = True
                        info["deleted_at"] = datetime.now().isoformat(timespec="seconds")
                    print("  Deleted.")
                except Exception as e:
                    print(f"  FAILED to delete: {e}")
            else:
                entry = files_by_dest.get(str(p))
                if entry:
                    _, info = entry
                    info["audited"] = True
                kept += 1
                print("  Kept and marked audited.")
    finally:
        save_manifest(manifest)

    print(f"\n=== Audit summary ===")
    print(f"Deleted: {deleted}")
    print(f"Kept:    {kept}")


def cmd_reorganize(args, cfg):
    library = load_library()
    library_index = index_library(library)
    franchises = load_franchises()
    library_root = Path(cfg["library_dir"])
    versions_root = Path(cfg["versions_dir"])
    manifest = load_manifest()

    moved = unchanged = missing = failed = 0

    for key, info in list(manifest.get("files", {}).items()):
        if info.get("status") != "downloaded":
            continue
        old_path_str = info.get("destination", "")
        if not old_path_str:
            continue
        old_path = Path(old_path_str)
        if not old_path.exists():
            missing += 1
            continue

        new_path = compute_full_dest(info, library_index, library_root, franchises, cfg)
        if new_path is None:
            continue
        if new_path == old_path:
            unchanged += 1
            continue

        if args.dry_run:
            print(f"WOULD MOVE: {old_path}")
            print(f"        -> {new_path}")
            moved += 1
            continue

        new_path.parent.mkdir(parents=True, exist_ok=True)
        if new_path.exists():
            ts = datetime.now().strftime("%Y%m%d-%H%M%S")
            vpath = versions_root / safe_dir(info["slug"],
                cfg.get("dir_replace_spaces", True)) / ts / new_path.name
            vpath.parent.mkdir(parents=True, exist_ok=True)
            shutil.move(str(new_path), str(vpath))
            log(f"  versioned existing {new_path} -> {vpath}")

        try:
            shutil.move(str(old_path), str(new_path))
            info["destination"] = str(new_path)
            info["renamed"] = new_path.name
            log(f"  moved {old_path} -> {new_path}")
            moved += 1
        except Exception as e:
            log(f"  FAILED to move {old_path}: {e}")
            failed += 1

    if not args.dry_run:
        save_manifest(manifest)
        for p in sorted([d for d in library_root.rglob("*") if d.is_dir()],
                        key=lambda x: -len(str(x))):
            try:
                p.rmdir()
            except OSError:
                pass

    verb = "Would move" if args.dry_run else "Moved"
    print(f"\n{verb}: {moved}, unchanged: {unchanged}, "
          f"missing-on-disk: {missing}, failed: {failed}")


