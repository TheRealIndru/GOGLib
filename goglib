    """Sensible default download location for new installs."""
    if IS_WINDOWS:
        # Windows users typically want games on a non-system drive; default to
        # Documents and let them edit config to point elsewhere.
        return HOME / "Documents" / "GOGLibrary"
    return HOME / "GOGLibrary"


