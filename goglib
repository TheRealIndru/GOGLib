                        ost_savings += parse_size(f.get("size"))
                        break

        if ost_savings:
            print(f"\nOST format priority filter ({' > '.join(ost_priority)}): "
                  f"will skip {fmt_size(ost_savings)} of duplicate format extras")

    print(f"\nGames matched: {len(games)}")
    print(f"Total advertised size (all files): {fmt_size(total_size)}")
    print("(Actual download will be smaller — manifest+OST blacklist applies.)")


def cmd_sync(args, cfg):
    library = load_library()
    games = filter_games(library, args.letter, args.game)
    if not games:
        print("No games match. Nothing to do.")
        return
    manifest = load_manifest()
    library_index = index_library(library)
    franchises = load_franchises()
    slugs = {g["gamename"] for g in games}

    n_done, n_ost, n_lang, n_user = build_blacklist(manifest, slugs, cfg, games)
    log(f"Sync: {len(slugs)} games. Blacklist: {n_done} already-known, "
        f"{n_ost} OST-priority, {n_lang} language, {n_user} user")

    # Self-check: verify our generated patterns actually match the paths lgog
    # will produce. Catches escaping bugs and pattern format regressions.
    if n_done > 0 and BLACKLIST_TMP.exists():
        try:
            patterns = []
            for line in BLACKLIST_TMP.read_text().splitlines():
                line = line.strip()
                if line.startswith("Rp "):
                    patterns.append(re.compile(line[3:]))
            sample_unmatched = []
            for slug in list(slugs)[:5]:
                for key, info in manifest.get("files", {}).items():
                    if info.get("slug") != slug:
                        continue
                    fname = info.get("original_filename", "")
                    if not fname:
                        continue
                    kind = info.get("kind", "installers")
                    sub = "" if kind == "installers" else f"{kind}/"
                    test_path = f"{slug}/{sub}{fname}"
                    if not any(p.search(test_path) for p in patterns):
                        sample_unmatched.append(test_path)
            if sample_unmatched:
                log(f"WARNING: {len(sample_unmatched)} manifest paths don't match "
                    f"any blacklist pattern. Sample: {sample_unmatched[:3]}")
        except re.error as e:
            log(f"WARNING: blacklist contains invalid regex: {e}")

    Path(cfg["staging_dir"]).mkdir(parents=True, exist_ok=True)
    game_re = "^(" + "|".join(re.escape(s) for s in sorted(slugs)) + ")$"

    backend = resolve_backend(cfg)
    log(f"Starting {backend.name} download")
    backend.download(cfg, game_re, BLACKLIST_TMP, REPORT_TMP, verbose=args.verbose)

    log("Post-processing")
    new_count, ver_count, skip_count = process_staging(
        cfg, slugs, library_index, franchises, manifest)
    save_manifest(manifest)
    log(f"Done. {new_count} added, {ver_count} versioned, {skip_count} failed.")

    unmapped = [s for s in slugs if s not in franchises]
    if unmapped:
        print(f"\n{len(unmapped)} games have no franchise mapping "
              f"(using {cfg.get('standalone_folder','Standalone')}/):")
        for s in sorted(unmapped)[:10]:
            print(f"  {s}")
        if len(unmapped) > 10:
            print(f"  ... and {len(unmapped) - 10} more")
        print(f"Edit {FRANCHISES_PATH} to map these, then run: goglib reorganize")


