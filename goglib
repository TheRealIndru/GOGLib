def load_franchises():
    if not FRANCHISES_PATH.exists():
        return {}
    with open(FRANCHISES_PATH) as f:
        data = json.load(f)
    return {k: v for k, v in data.items() if not k.startswith("_")}


def load_manifest():
    if MANIFEST_PATH.exists():
        with open(MANIFEST_PATH) as f:
            return json.load(f)
    return {"version": 4, "files": {}}


def save_manifest(m):
    MANIFEST_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = MANIFEST_PATH.with_suffix(".json.tmp")
    with open(tmp, "w") as f:
        json.dump(m, f, indent=2, sort_keys=True)
    tmp.replace(MANIFEST_PATH)


# ---------- library ----------
def load_library():
    if not LIBRARY_JSON.exists():
        sys.exit(f"No library JSON at {LIBRARY_JSON}. Run: goglib refresh")
    with open(LIBRARY_JSON) as f:
        return json.load(f)


def index_library(library):
    return {g["gamename"]: g for g in library if "gamename" in g}


# ---------- filtering ----------
# Articles to strip when computing a game's "first letter" for sorting/filtering.
# Mirrors common library-cataloging convention. Sorted longest-first so multi-
# word entries match before single-word ones.
SORT_ARTICLES = ("the ", "an ", "a ")


def title_first_char(title_or_slug):
    """Return the lowercase character used to bucket a game for letter-filtering.
    
    Strips leading articles ('The', 'A', 'An') and falls back through any
    leading non-alphanumeric noise (punctuation, whitespace) to find the first
    real character. Returns '0-9' for digits, the lowercase letter otherwise,
    or '?' if nothing usable found.
    """
    if not title_or_slug:
        return "?"
    s = title_or_slug.lower().lstrip()
    # Strip leading article(s). One pass suffices since articles never stack.
    for art in SORT_ARTICLES:
        if s.startswith(art):
            s = s[len(art):].lstrip()
            break
    # Skip leading non-alphanumeric noise (e.g. quotation marks, punctuation)
    for ch in s:
        if ch.isdigit():
            return "0-9"
        if ch.isalpha():
            return ch
    return "?"


def title_for_filter(game):
    """Title used by letter-filter and status histogram. Falls back to slug."""
    return game.get("title") or game.get("gamename") or ""


def letter_to_regex(letter):
    """Validates the letter input. Returned regex isn't used directly anymore
    (filter_games now compares against title_first_char) but we keep the
    function for input validation and for `all`/`num` shortcuts."""
    letter = letter.lower()
    if letter in ("num", "numeric", "0-9"):
        return "0-9"
    if letter == "all":
        return "*"
    if re.fullmatch(r"[a-z]", letter):
        return letter
    if re.fullmatch(r"[a-z]-[a-z]", letter):
        return letter
    sys.exit(f"Bad --letter '{letter}'. Use: num | all | a | a-c")


def matches_letter_filter(game, letter_spec):
    """Test if a game's first-letter (after article-stripping) falls within
    the letter spec. letter_spec is the validated string from letter_to_regex."""
    if letter_spec == "*":
        return True
    bucket = title_first_char(title_for_filter(game))
    if letter_spec == "0-9":
        return bucket == "0-9"
    if len(letter_spec) == 1:
        return bucket == letter_spec
    if len(letter_spec) == 3 and letter_spec[1] == "-":
        a, b = letter_spec[0], letter_spec[2]
        return bucket != "0-9" and bucket != "?" and a <= bucket <= b
    return False


def filter_games(library, letter=None, game_regex=None):
    """Apply --letter and --game filters.
    
    --letter buckets by display title's first letter (after stripping leading
    'The'/'A'/'An'). So 'The Witcher' lives under 'w', 'A Plague Tale' under
    'p' wait — under 'a' since 'A Plague Tale' has 'A' as article AND 'P'
    as content; we strip the article so under 'p'. 'Blackwell Legacy'
    (slug 'episode_1_the_blackwell_legacy') buckets under 'b'.
    
    --game still matches against the SLUG (so existing usage like
    --game ^homm continues to work).
    """
    letter_spec = letter_to_regex(letter) if letter else None
    game_re = re.compile(game_regex, re.IGNORECASE) if game_regex else None

    out = []
    for g in library:
        if letter_spec is not None and not matches_letter_filter(g, letter_spec):
            continue
        if game_re is not None and not game_re.search(g.get("gamename", "")):
            continue
        out.append(g)
    return out


def expected_size_total(game):
    total = 0
    count = 0
    for kind in ("installers", "patches", "extras", "languagepacks"):
        for f in (game.get(kind) or []):
            total += parse_size(f.get("size"))
            count += 1
    return total, count


# ---------- destination resolution ----------
def franchise_lookup(slug, franchises):
    info = franchises.get(slug)
    if not info:
        return None, None, None
    return info.get("franchise"), info.get("year"), info.get("title")


def is_dlc(game):
    slug = game.get("gamename")
    basegame = game.get("gamename_basegame")
    return bool(basegame and basegame != slug)


def target_dir_for(game, library_index, library_root, franchises, cfg):
    """Compute destination directory for a game (or DLC).
    
    For DLCs with flatten_dlc_folder=True, returns <base>/dlc/ — files will
    be renamed with the DLC slug prefixed.
    """
    title = game.get("title") or game.get("gamename") or "?"
    slug = game.get("gamename")
    basegame = game.get("gamename_basegame")
    dlc = is_dlc(game)

    lookup_slug = basegame if dlc else slug
    lookup_game = library_index.get(lookup_slug, game)
    lookup_title = lookup_game.get("title") or lookup_slug

    franchise, year, sort_title = franchise_lookup(lookup_slug, franchises)

    title_for_folder = sort_title or lookup_title
    if year:
        folder_name = f"{year}_{title_for_folder}"
    else:
        folder_name = title_for_folder

    rs = bool(cfg.get("dir_replace_spaces", True))
    standalone = cfg.get("standalone_folder", "Standalone")

    if franchise:
        base_dir = library_root / safe_dir(franchise, rs) / safe_dir(folder_name, rs)
    else:
        base_dir = library_root / standalone / safe_dir(folder_name, rs)

    if dlc:
        if cfg.get("flatten_dlc_folder", True):
            return base_dir / "dlc"
        return base_dir / "dlc" / safe_dir(title, rs)
    return base_dir


def rename_for_target(original, cfg, dlc_slug=None):
    """Apply prefix-strip + pattern. For DLC files with flatten_dlc_folder,
    prefix the DLC slug to avoid filename collisions across DLCs."""
    prefix = cfg.get("filename_strip_prefix", "")
    stripped = original
    if prefix and stripped.startswith(prefix):
        stripped = stripped[len(prefix):]
    pattern = cfg.get("filename_pattern", "{stripped}")
    name = pattern.format(stripped=stripped, original=original)
    if dlc_slug and cfg.get("flatten_dlc_folder", True):
        name = f"{dlc_slug}__{name}"
    return name


def derive_kind(rel_parent_str):
    if rel_parent_str == "." or rel_parent_str == "":
        return "installers", ""
    first = rel_parent_str.split("/", 1)[0].lower()
    if first in ("extras", "patches", "languagepacks", "language_packs", "dlc"):
        kind_map = {"language_packs": "languagepacks"}
        return kind_map.get(first, first), rel_parent_str
    return "installers", rel_parent_str


def compute_full_dest(file_info, library_index, library_root, franchises, cfg):
    """Compute current target path for a manifest entry."""
    slug = file_info["slug"]
    game = library_index.get(slug)
    if not game:
        return None
    target_dir = target_dir_for(game, library_index, library_root, franchises, cfg)
    kind = file_info.get("kind", "installers")
    sub = "" if kind == "installers" else kind

    dlc_slug = slug if is_dlc(game) and cfg.get("flatten_dlc_folder", True) else None
    new_name = rename_for_target(file_info["original_filename"], cfg, dlc_slug=dlc_slug)

    if sub:
        return target_dir / sub / new_name
    return target_dir / new_name


# ---------- OST format priority ----------
def detect_ost_format(filename):
    """Return (is_ost, format) where format is 'flac'/'wav'/'mp3'/'ogg'/None.
    
    Returns (False, None) if not detected as an OST file.
    Returns (True, None) if looks like OST but format unclear (don't filter).
    """
    name = filename.lower()
    # Strip extension(s) for marker check
    base = re.sub(r"\.(zip|tar|gz|7z|rar)$", "", name)
    base = re.sub(r"\.(zip|tar|gz|7z|rar)$", "", base)  # double strip if needed

    # Must contain an OST marker as a token (between _, -, or word boundary)
    if not re.search(r"(?:^|[_\-.])(" + "|".join(OST_MARKERS) + r")(?:[_\-.]|$)", base):
        return False, None

    # Look for format suffix or extension
    fmt_match = re.search(r"[_\-.](flac|wav|mp3|ogg|m4a|aac)(?:[_\-.]|$)", base)
    if fmt_match:
        return True, fmt_match.group(1)

    # File extension fallback
    ext_match = re.search(r"\.(flac|wav|mp3|ogg|m4a|aac)$", name)
    if ext_match:
        return True, ext_match.group(1)

    # OST detected but no format identifiable — don't filter
    return True, None


def build_ost_blacklist_for_game(game, priority):
    """For each game, group OST files by format, pick highest priority,
    and return list of regex patterns to blacklist for the others.
    
    Patterns target the filename as it appears under <slug>/<sub>/<filename>.
    """
    if not priority:
        return []
    extras = game.get("extras") or []
    if not extras:
        return []

    by_format = {}  # format → list of filenames
    unknown_ost = []  # OST detected but format unclear
    for f in extras:
        # 'path' in lgog JSON is usually just the bare filename. Only fall
        # back to splitting if it has slashes. 'name' is a display label,
        # NOT a filename.
        path = f.get("path") or ""
        fname = path.rsplit("/", 1)[-1] if "/" in path else path
        if not fname:
            continue
        is_ost, fmt = detect_ost_format(fname)
        if not is_ost:
            continue
        if fmt:
            by_format.setdefault(fmt, []).append(fname)
        else:
            unknown_ost.append(fname)

    if len(by_format) < 2:
        return []  # only one format present; nothing to blacklist

    # Pick the best format we have
    best = None
    for p in priority:
        if p in by_format:
            best = p
            break
    if best is None:
        return []  # none of our priority formats present

    # Blacklist everything not in best
    patterns = []
    slug = game.get("gamename", "")
    for fmt, files in by_format.items():
        if fmt == best:
            continue
        for fname in files:
            # No leading ^ — see manifest blacklist comment above
            patterns.append(f"{re.escape(slug)}/(.*/)?{re.escape(fname)}$")
    return patterns


# ---------- backend abstraction ----------
def run(cmd, check=True, **kw):
    print(f"$ {' '.join(cmd)}")
    return subprocess.run(cmd, check=check, **kw)


class LgogDownloaderBackend:
    """Backend wrapping lgogdownloader (Linux/macOS, also runs under WSL)."""

    name = "lgogdownloader"
    binary = "lgogdownloader"

    @classmethod
    def is_available(cls):
        return shutil.which(cls.binary) is not None

    @classmethod
    def refresh(cls, cfg):
        run([cls.binary, "--update-cache",
             "--platform", cfg["platform"],
             "--language", cfg["language"]])

    @classmethod
    def dump_library(cls, cfg, out_path):
        with open(out_path, "w") as f:
            subprocess.run(
                [cls.binary, "--list", "j",
                 "--platform", cfg["platform"],
                 "--language", cfg["language"]],
                stdout=f, check=True)

    @classmethod
    def download(cls, cfg, game_re, blacklist_path, report_path, verbose=False):
        args = [
            cls.binary, "--download",
            "--directory", cfg["staging_dir"],
            "--game", game_re,
            "--platform", cfg["platform"],
            "--language", cfg["language"],
            "--include", cfg["include"],
            "--blacklist", str(blacklist_path),
            "--threads", str(cfg["threads"]),
            "--report", str(report_path),
        ]
        if verbose:
            args.extend(["--verbosity", "1"])
        if cfg.get("exclude"):
            args.extend(["--exclude", cfg["exclude"]])
        run(args, check=False)


class GogRepoCBackend:
    """Backend wrapping gogrepoc (Python; works on Windows, Linux, macOS).

    Translates goglib's lgogdownloader-shaped contract to gogrepoc's CLI.
    Output JSON format differs from lgogdownloader, so dump_library reshapes
    it to match what the rest of goglib expects.

    See: https://github.com/Yepoleb/gogrepoc
    """

    name = "gogrepoc"
    binary = "gogrepo.py"  # may also be 'gogrepoc' depending on install

    @classmethod
    def is_available(cls):
        for cand in ("gogrepoc", "gogrepo.py", "gogrepo"):
            if shutil.which(cand):
                cls.binary = cand
                return True
        return False

    @classmethod
    def _translate_platform(cls, platform_spec):
        """lgog 'w+l' -> gogrepoc OS list."""
        out = []
        for p in re.split(r"[+,]", platform_spec.lower()):
            p = p.strip()
            if p in ("w", "win", "windows"):
                out.append("windows")
            elif p in ("l", "lin", "linux"):
                out.append("linux")
            elif p in ("m", "mac", "osx"):
                out.append("mac")
        return out or ["windows", "linux"]

    @classmethod
    def _translate_language(cls, lang_spec):
        """lgog 'en+ro+ja' -> gogrepoc lang list."""
        out = []
        for p in re.split(r"[+,]", lang_spec.lower()):
            p = p.strip()
            if not p or p == "all":
                continue
            # gogrepoc uses 2-letter codes
            out.append(p[:2])
        return out or ["en"]

    @classmethod
    def refresh(cls, cfg):
        plats = cls._translate_platform(cfg["platform"])
        langs = cls._translate_language(cfg["language"])
        args = [cls.binary, "update", "-os"] + plats + ["-lang"] + langs
        run(args, check=False)

    @classmethod
    def dump_library(cls, cfg, out_path):
        """Read gogrepoc's manifest.dat (or equivalent) and reshape into the
        lgogdownloader JSON format that goglib expects.

        gogrepoc stores its metadata in a Python pickle file by default, plus
        an optional JSON export via 'gogrepoc dump'. We invoke that and then
        massage the structure to match.
        """
        # gogrepoc dumps its metadata to manifest.json on demand
        gogrepo_dir = _state_dir() / "gogrepoc-work"
        gogrepo_dir.mkdir(parents=True, exist_ok=True)
        manifest_dat = gogrepo_dir / "gog-manifest.dat"
        # Run gogrepoc 'list' which prints a structured list
        # We then convert it.
        # Note: gogrepoc's data model is per-game with an installers/extras list,
        # which mostly matches lgogdownloader's. We do a minimal shape conversion.
        try:
            res = subprocess.run(
                [cls.binary, "list", "--json"],
                capture_output=True, text=True, check=True)
            data = json.loads(res.stdout)
        except (subprocess.CalledProcessError, json.JSONDecodeError, FileNotFoundError) as e:
            sys.exit(
                f"gogrepoc list failed: {e}\n"
                f"Verify gogrepoc is installed and you've run: {cls.binary} login\n"
                f"See https://github.com/Yepoleb/gogrepoc for installation.")

        # Reshape gogrepoc's output to match lgogdownloader's JSON list format
        out = []
        for entry in data:
            game = {
                "gamename": entry.get("gamename") or entry.get("title", "").lower().replace(" ", "_"),
                "title": entry.get("title", ""),
                "gamename_basegame": entry.get("base_gamename"),
                "title_basegame": entry.get("base_title"),
                "installers": entry.get("installers", []),
                "extras": entry.get("extras", []),
                "patches": entry.get("patches", []),
                "languagepacks": entry.get("language_packs", []),
                "icon": entry.get("icon", ""),
                "product_id": entry.get("product_id"),
                "serials": entry.get("serials", []),
                "changelog": entry.get("changelog", ""),
            }
            out.append(game)

        with open(out_path, "w") as f:
            json.dump(out, f)

    @classmethod
    def download(cls, cfg, game_re, blacklist_path, report_path, verbose=False):
        plats = cls._translate_platform(cfg["platform"])
        langs = cls._translate_language(cfg["language"])
        # gogrepoc takes a list of game IDs; expanding the regex against the
        # library JSON is goglib's job.
        if not LIBRARY_JSON.exists():
            sys.exit(f"Need {LIBRARY_JSON} to expand --game regex for gogrepoc. "
                     f"Run: goglib refresh")
        with open(LIBRARY_JSON) as f:
            library = json.load(f)
        pat = re.compile(game_re)
        slugs = [g["gamename"] for g in library
                 if g.get("gamename") and pat.search(g["gamename"])]

        if not slugs:
            log("gogrepoc: no slugs match")
            return

        # gogrepoc's download skips files already present on disk; we want
        # manifest-driven skipping instead. Pre-walk staging and remove files
        # that are in the blacklist BEFORE the download, so gogrepoc doesn't
        # see them as "needs verifying".
        # (Implementation note: gogrepoc lacks a blacklist option as of this
        # writing, so the manifest blacklist is enforced solely by goglib's
        # post-processing — gogrepoc may overdownload but goglib's process
        # step still produces correct manifest state.)

        args = [cls.binary, "download",
                cfg["staging_dir"],
                "-id"] + slugs
        if cfg.get("threads"):
            args.extend(["-threads", str(cfg["threads"])])
        if not verbose:
            args.append("-q")  # quiet
        run(args, check=False)


BACKENDS = {
    "lgogdownloader": LgogDownloaderBackend,
    "gogrepoc": GogRepoCBackend,
}


def resolve_backend(cfg):
    """Pick a backend based on config and OS detection."""
    name = cfg.get("backend", "auto").lower()
    if name == "auto":
        # Default per OS
        if IS_WINDOWS:
            preferred = [GogRepoCBackend, LgogDownloaderBackend]
        else:
            preferred = [LgogDownloaderBackend, GogRepoCBackend]
        for b in preferred:
            if b.is_available():
                return b
        sys.exit(
            "No GOG download backend found. Install one:\n"
            "  Linux/macOS: lgogdownloader (apt install lgogdownloader, or build from source)\n"
            "  Windows:     gogrepoc       (pip install gogrepoc, then 'gogrepoc login')")
    if name in BACKENDS:
        b = BACKENDS[name]
        if not b.is_available():
            sys.exit(f"Backend '{name}' is configured but not available on PATH.")
        return b
    sys.exit(f"Unknown backend '{name}'. Choose from: {list(BACKENDS)} or 'auto'.")


